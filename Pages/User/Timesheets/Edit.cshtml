@page
@model PayrollManagementSystem.Pages.User.Timesheets.EditModel
@{
    ViewData["Title"] = "Weekly Timesheet";
    bool isReadOnly = Model.TimesheetVm.Status != "Draft";
}

<partial name="_UserPartial" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">My Timesheet</h2>
            <p class="text-muted mb-0">
                Week of @Model.TimesheetVm.WeekStart.ToString("MMMM dd, yyyy")
            </p>
        </div>

        <div>
            @if (Model.TimesheetVm.Status == "Draft")
            {
                <span class="badge bg-secondary fs-6">Draft</span>
            }
            else if (Model.TimesheetVm.Status == "Submitted")
            {
                <span class="badge bg-primary fs-6">Submitted</span>
            }
            else if (Model.TimesheetVm.Status == "Approved")
            {
                <span class="badge bg-success fs-6">Approved</span>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <a asp-page="./Edit"
                   asp-route-weekStart="@Model.TimesheetVm.PreviousWeekStart.ToString("yyyy-MM-dd")"
                   class="btn btn-outline-secondary">
                    Previous Week
                </a>

                <a asp-page="./Edit"
                   asp-route-weekStart="@Model.TimesheetVm.NextWeekStart.ToString("yyyy-MM-dd")"
                   class="btn btn-outline-secondary">
                    Next Week
                </a>
            </div>

            <form method="post">
                <input type="hidden" asp-for="TimesheetVm.TimesheetId" />
                <input type="hidden" asp-for="TimesheetVm.EmployeeId" />
                <input type="hidden" asp-for="TimesheetVm.WeekStart" />
                <input type="hidden" asp-for="TimesheetVm.Status" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 20%">Day</th>
                                <th style="width: 20%">Date</th>
                                <th style="width: 20%">Hours</th>
                                <th style="width: 40%">Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.TimesheetVm.Days.Count; i++)
                            {
                                <tr>
                                    <td>
                                        @Model.TimesheetVm.Days[i].DayName
                                        <input type="hidden" asp-for="TimesheetVm.Days[i].WorkDate" />
                                    </td>
                                    <td>@Model.TimesheetVm.Days[i].DisplayDate</td>
                                    <td>
                                        <input asp-for="TimesheetVm.Days[i].HoursWorked"
                                               class="form-control"
                                               step="0.25"
                                               min="0"
                                               max="24"
                                               readonly="@isReadOnly" />
                                        <span asp-validation-for="TimesheetVm.Days[i].HoursWorked" class="text-danger"></span>
                                    </td>
                                    <td>
                                        <input asp-for="TimesheetVm.Days[i].Notes"
                                               class="form-control"
                                               readonly="@isReadOnly" />
                                        <span asp-validation-for="TimesheetVm.Days[i].Notes" class="text-danger"></span>
                                    </td>
                                </tr>
                            }
                            <tr class="table-light fw-bold">
                                <td colspan="2">Total</td>
                                <td>@Model.TimesheetVm.TotalHours</td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                @if (!isReadOnly)
                {
                    <div class="d-flex gap-2">
                        <button type="submit" asp-page-handler="Save" class="btn btn-outline-primary">
                            Save Draft
                        </button>
                        <button type="submit" asp-page-handler="Submit" class="btn btn-primary">
                            Submit Timesheet
                        </button>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}