@page
@model PayrollManagementSystem.Pages.User.IndexModel
@{
    ViewData["Title"] = "User Dashboard";
}

<partial name="_UserPartial" />

<div class="container mt-4">
    <div class="mb-4">
        <h1 class="fw-bold">User Dashboard</h1>
        <p class="text-muted">
            Review the status of your most recent weekly timesheets.
        </p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h4 class="mb-1 fw-bold">Status of your last timesheets</h4>
                    <p class="text-muted mb-0">
                        Showing the most recent 5 weekly timesheets.
                    </p>
                </div>
            </div>

            @if (Model.RecentTimesheets.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var item in Model.RecentTimesheets)
                    {
                        <div class="list-group-item px-0 py-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

                                <div>
                                    <div class="fw-semibold">
                                        Week of @item.WeekStartDisplay to @item.WeekEndDisplay
                                    </div>
                                </div>

                                <div class="d-flex align-items-center gap-3">

                                    <div>
                                        @if (item.Status == "Submitted")
                                        {
                                            <span class="badge bg-primary fs-6">Submitted</span>
                                        }
                                        else if (item.Status == "Approved")
                                        {
                                            <span class="badge bg-success fs-6">Approved</span>
                                        }
                                        else if (item.Status == "Draft")
                                        {
                                            <span class="badge bg-secondary fs-6">Draft</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark fs-6">@item.Status</span>
                                        }
                                    </div>

                                    <a asp-page="/User/Timesheets/Edit"
                                       asp-route-weekStart="@item.WeekStart.ToString("yyyy-MM-dd")"
                                       class="btn btn-sm btn-outline-primary">
                                        View Timesheet
                                    </a>

                                </div>

                            </div>
                        </div>
                    }

                </div>
            }
            else
            {
                <div class="alert alert-light border mt-3 mb-0">
                    No timesheet records found for the past few weeks.
                </div>
            }
        </div>
    </div>
</div>
