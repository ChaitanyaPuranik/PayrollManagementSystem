@page "{timesheetId:int}"
@model PayrollManagementSystem.Pages.Admin.Timesheets.ReviewModel
@{
    ViewData["Title"] = "Review Timesheet";
}

<partial name="_AdminPartial" />

<div class="container mt-4">
    @if (Model.TimesheetVm != null)
    {
        <div class="mb-4">
            <h1 class="fw-bold">Review Timesheet</h1>
            <p class="text-muted mb-0">
                @Model.TimesheetVm.EmployeeName • Week of @Model.TimesheetVm.WeekStart.ToString("MMM dd, yyyy")
            </p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="text-muted small">Employee</div>
                        <div class="fw-semibold">@Model.TimesheetVm.EmployeeName</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Email</div>
                        <div class="fw-semibold">@Model.TimesheetVm.EmployeeEmail</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Status</div>
                        <div class="fw-semibold">@Model.TimesheetVm.Status</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Week</div>
                        <div class="fw-semibold">
                            @Model.TimesheetVm.WeekStart.ToString("ddd yyyy.MM.dd")
                            to
                            @Model.TimesheetVm.WeekEnd.ToString("ddd yyyy.MM.dd")
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Submitted At</div>
                        <div class="fw-semibold">
                            @(Model.TimesheetVm.SubmittedAt?.ToString("MMM dd, yyyy hh:mm tt") ?? "-")
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Total Hours</div>
                        <div class="fw-semibold">@Model.TimesheetVm.TotalHours.ToString("0.##")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-3">Daily Entries</h4>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Day</th>
                                <th>Date</th>
                                <th>Hours</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model.TimesheetVm.Entries)
                            {
                                <tr>
                                    <td>@entry.WorkDate.ToString("dddd")</td>
                                    <td>@entry.WorkDate.ToString("MMM dd, yyyy")</td>
                                    <td>@entry.HoursWorked.ToString("0.##")</td>
                                    <td>@(string.IsNullOrWhiteSpace(entry.Notes) ? "-" : entry.Notes)</td>
                                </tr>
                            }
                            <tr class="table-light fw-bold">
                                <td colspan="2">Total</td>
                                <td>@Model.TimesheetVm.TotalHours.ToString("0.##")</td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <a asp-page="/Admin/Timesheets/Index" class="btn btn-outline-secondary">Back</a>
                    <a asp-page="/Admin/PayrollRuns/Generate"
                       asp-route-weekStart="@Model.TimesheetVm.WeekStart.ToString("yyyy-MM-dd")"
                       class="btn btn-primary">
                        Go To Generate Payroll
                    </a>
                </div>
            </div>
        </div>
    }
</div>