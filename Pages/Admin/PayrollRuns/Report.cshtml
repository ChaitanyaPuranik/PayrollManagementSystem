@page "{payRunId:int}"
@model PayrollManagementSystem.Pages.Admin.PayrollRuns.ReportModel
@{
    ViewData["Title"] = "Payroll Report";
}

<partial name="_AdminPartial" />

<div class="container mt-4">
    @if (Model.ReportVm != null)
    {
        <div class="mb-4">
            <h1 class="fw-bold">Payroll Report</h1>
            <p class="text-muted mb-0">
                Pay Run ID: @Model.ReportVm.PayRunId
            </p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="text-muted small">Week</div>
                        <div class="fw-semibold">
                            @Model.ReportVm.WeekStart.ToString("ddd yyyy.MM.dd")
                            to
                            @Model.ReportVm.WeekEnd.ToString("ddd yyyy.MM.dd")
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">Run Date</div>
                        <div class="fw-semibold">@Model.ReportVm.RunDate.ToString("MMM dd, yyyy hh:mm tt")</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">Status</div>
                        <div class="fw-semibold">@Model.ReportVm.Status</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">Employees Included</div>
                        <div class="fw-semibold">@Model.ReportVm.Details.Count</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-3">Payroll Details</h4>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Employee ID</th>
                                <th>Employee Name</th>
                                <th>Gross Pay</th>
                                <th>Tax Amount</th>
                                <th>Net Pay</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in Model.ReportVm.Details)
                            {
                                <tr>
                                    <td>@detail.EmployeeId</td>
                                    <td>@detail.EmployeeName</td>
                                    <td>$@detail.GrossPay.ToString("0.00")</td>
                                    <td>$@detail.TaxAmount.ToString("0.00")</td>
                                    <td>$@detail.NetPay.ToString("0.00")</td>
                                </tr>
                            }
                            <tr class="table-light fw-bold">
                                <td colspan="2">Totals</td>
                                <td>$@Model.ReportVm.TotalGross.ToString("0.00")</td>
                                <td>$@Model.ReportVm.TotalTax.ToString("0.00")</td>
                                <td>$@Model.ReportVm.TotalNet.ToString("0.00")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <a asp-page="/Admin/PayrollRuns/Index" class="btn btn-outline-secondary">Back</a>
                </div>
            </div>
        </div>
    }
</div>