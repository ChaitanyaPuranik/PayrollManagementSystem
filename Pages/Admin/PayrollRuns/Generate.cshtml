@page
@model PayrollManagementSystem.Pages.Admin.PayrollRuns.GenerateModel
@{
    ViewData["Title"] = "Generate Payroll";
}

<partial name="_AdminPartial" />

<div class="container mt-4">
    <div class="mb-4">
        <h1 class="fw-bold">Generate Payroll</h1>
        <p class="text-muted mb-0">
            Select a week with submitted timesheets and generate payroll.
        </p>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="SelectedWeekStart" class="form-label">Week Start</label>
                    <input asp-for="SelectedWeekStart" type="date" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">Generate Payroll</button>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h4 class="fw-bold mb-3">Available Weeks</h4>

            @if (Model.AvailableWeeks.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Week</th>
                                <th>Submitted Timesheets</th>
                                <th>Total Hours</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var week in Model.AvailableWeeks)
                            {
                                <tr>
                                    <td>
                                        @week.WeekStart.ToString("ddd yyyy.MM.dd")
                                        to
                                        @week.WeekEnd.ToString("ddd yyyy.MM.dd")
                                    </td>
                                    <td>@week.SubmittedTimesheetCount</td>
                                    <td>@week.TotalHours.ToString("0.##")</td>
                                    <td class="text-end">
                                        <a asp-page="./Generate"
                                           asp-route-weekStart="@week.WeekStart.ToString("yyyy-MM-dd")"
                                           class="btn btn-sm btn-outline-primary">
                                            Select
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-light border mb-0">
                    No submitted timesheets available for payroll generation.
                </div>
            }
        </div>
    </div>
</div>